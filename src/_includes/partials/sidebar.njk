<aside class="sidebar" data-sidebar>
  <div class="sidebar-info">
    <figure class="avatar-box">
      <img src="{{ profile.avatar.src }}" alt="{{ profile.avatar.alt }}" width="{{ profile.avatar.width }}">
    </figure>

    <div class="info-content">
      <h1 class="name" title="{{ profile.name }}">{{ profile.name }}</h1>
      <p class="title">{{ profile.title }}</p>
    </div>

    <button class="info_more-btn" data-sidebar-btn>
      <span>Show Contacts</span>
      <ion-icon name="chevron-down"></ion-icon>
    </button>
  </div>

  <div class="sidebar-info_more">
    <div class="separator"></div>

    <ul class="contacts-list">
      {% for item in profile.contacts %}
        <li class="contact-item">
          <div class="icon-box">
            <ion-icon name="{{ item.icon }}"></ion-icon>
          </div>
          <div class="contact-info">
            <p class="contact-title">{{ item.title }}</p>

            {% if item.links %}
              {% for link in item.links %}
                <a href="{{ link.href }}" class="contact-link" target="_blank" rel="noopener noreferrer">{{ link.label }}</a>
              {% endfor %}
            {% endif %}

            {% if item.time %}
              <time datetime="{{ item.time.datetime }}">{{ item.time.label }}</time>
            {% endif %}

            {% if item.address %}
              <address>{{ item.address }}</address>
            {% endif %}
          </div>
        </li>
      {% endfor %}
    </ul>

    <div class="separator"></div>

    <ul class="social-list">
      {% for link in profile.socialLinks %}
        <li class="social-item">
          <a href="{{ link.href }}" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="{{ link.label }}">
            <ion-icon name="{{ link.icon }}"></ion-icon>
          </a>
        </li>
      {% endfor %}
    </ul>
  </div>
</aside>
